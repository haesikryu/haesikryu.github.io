{
  "name": "haesikryu-blog-rag",
  "private": true,
  "version": "1.0.0",
  "description": "Build-time embeddings + client RAG widget for Jekyll/GitHub Pages",
  "type": "module",
  "scripts": {
    "generate-embeddings": "node scripts/generate-vector-store.js",
    "generate-graph": "node scripts/generate-graph-data.js",
    "update-stats": "node scripts/update-graph-stats.js",
    "dev": "vite",
    "build:rag": "vite build",
    "build:kg": "vite build --config vite.kg.config.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "marked": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.3.3",
    "d3-force": "^3.0.0",
    "force-graph": "^1.51.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
