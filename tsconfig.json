{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "types/**/*.ts",
    "utils/**/*.ts",
    "components/**/*.tsx",
    "scripts/**/*.ts",
    "hooks/**/*.ts",
    "constants/**/*.ts",
    "contexts/**/*.tsx",
    "rag-chat/**/*.tsx"
  ],
  "exclude": ["node_modules", "_site", "vendor"]
}
